{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorldPop acquisition request",
  "type": "object",
  "required": ["tool", "project", "iso3", "root"],
  "properties": {
    "tool": {
      "type": "string",
      "enum": ["discover_worldpop", "acquire_worldpop_population"]
    },
    "project": {
      "type": "string",
      "description": "WorldPop project/product alias, for example wpgp."
    },
    "iso3": {
      "type": "string",
      "pattern": "^[A-Za-z]{3}$"
    },
    "year": { "type": "integer" },
    "contains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extensions": {
      "type": "array",
      "items": { "type": "string" },
      "default": [".tif", ".tiff", ".zip"]
    },
    "download": { "type": "boolean", "default": false },
    "limit": { "type": "integer", "minimum": 1 },
    "root": {
      "type": "string",
      "description": "Local-only cache root under the configured AirMosaic local workspace."
    }
  },
  "additionalProperties": false
}
